# IRC Memory Lane - Environment Configuration

# API Base URL
# Production: https://tools.tornevall.net
# Staging: https://tools.tornevall.com
# Development: http://localhost:8000
VITE_API_URL=https://tools.tornevall.net

# Base path for deployment
# Recommended (portable): BASE_URL=./  (assets resolved relative to index.html)
# Root deployment (absolute): BASE_URL=/
# Subdirectory deployment: BASE_URL=/irclogs-react/
BASE_URL=./

# App Configuration
VITE_APP_NAME=IRC Memory Lane
VITE_APP_VERSION=1.0.0
