# IRC Memory Lane - Environment Configuration

# API Base URL
# Production: https://tools.tornevall.net
# Staging: https://tools.tornevall.com
# Development: http://localhost:8000
VITE_API_URL=https://tools.tornevall.net
# Optional shorthand target (ignored when VITE_API_URL is set):
# VITE_API_TARGET=prod  # -> https://tools.tornevall.net
# VITE_API_TARGET=test  # -> https://tools.tornevall.com

# Read source for IRC logs API (production|sandbox)
# Set to sandbox to browse imported-but-not-approved data.
VITE_IRCLOG_READ_SOURCE=production

# Build asset base (optional override)
# Default behavior is already relative ("./"), which auto-follows current URL path.
# Set only if you explicitly need an absolute base.
# Example: VITE_BASE_URL=/irclogs-react/
# VITE_BASE_URL=./

# App Configuration
VITE_APP_NAME=IRC Memory Lane
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production
